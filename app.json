{
  "expo": {
    "name": "Sanidapp",
    "slug": "sanidapp",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "sanidapp",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.gr2206.sanidapp",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Sanidapp"
      }
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "sanidapp",
              "host": "protocol"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.gr2206.sanidapp",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1E7E34",
          "defaultChannel": "foro-sum",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/icon.png",
          "imageWidth": 128,
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 128
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Sanidapp necesita acceso a la cámara para escanear códigos QR de protocolos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Sanidapp guarda eventos del Foro en el calendario de tu celular cuando lo solicitás."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "useLegacyPackaging": false
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "react-native-iap",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "645edc66-3198-43aa-a280-298151eda3c3"
      }
    },
    "owner": "g2206"
  }
}
