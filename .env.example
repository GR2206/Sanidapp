# Copiá este archivo a .env en la raíz del proyecto (no lo subas a git).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Admin bootstrap (opcional): UIDs de Firebase Auth separados por coma.
# También podés usar Firestore → apps/sanidapp/config/admins → { "uids": ["..."] }
EXPO_PUBLIC_ADMIN_UIDS=

# Google Play — suscripción premium (debe coincidir con Play Console; build AAB al final)
EXPO_PUBLIC_IAP_PREMIUM_PRODUCT_ID=sanidapp_premium

# Cloud Functions (último paso, tras Play Console): firebase functions:secrets:set GOOGLE_PLAY_SERVICE_ACCOUNT_JSON

# Builds EAS (preview/production): cargá las mismas EXPO_PUBLIC_* en
# https://expo.dev/accounts/g2206/projects/sanidapp/environment-variables
# Entorno: preview (APK de prueba) y production (Play Store).
