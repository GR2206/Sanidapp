rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {



    function isSignedIn() {

      return request.auth != null;

    }



    function isAdmin() {

      return isSignedIn() && (

        (exists(/databases/$(database)/documents/apps/sanidapp/config/admins)

          && request.auth.uid in get(/databases/$(database)/documents/apps/sanidapp/config/admins).data.uids)

        || (hasUserProfile() && userProfile().role == 'admin')

      );

    }



    function isSelf(uid) {

      return isSignedIn() && request.auth.uid == uid;

    }



    function userProfilePath() {

      return /databases/$(database)/documents/apps/sanidapp/usuarios/$(request.auth.uid);

    }



    function hasUserProfile() {

      return isSignedIn() && exists(userProfilePath());

    }



    function userProfile() {

      return get(userProfilePath()).data;

    }



    function belongsToSanatorio(sanatorioId) {

      return hasUserProfile() && userProfile().sanatorioId == sanatorioId;

    }



    function isSupervisorOf(sanatorioId) {

      return hasUserProfile()

        && userProfile().role == 'supervisor'

        && userProfile().sanatorioId == sanatorioId;

    }



    function foroPostTargetUid(data) {

      return data.keys().hasAny(['targetUid'])

        && data.targetUid is string

        && data.targetUid.size() > 0

        ? data.targetUid

        : null;

    }



    function canReadForoPost(sanatorioId, data) {

      return isAdmin()

        || (belongsToSanatorio(sanatorioId) && (

          foroPostTargetUid(data) == null

          || foroPostTargetUid(data) == request.auth.uid

          || data.authorUid == request.auth.uid

        ));

    }



    function roleUnchanged() {

      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);

    }



    function premiumFieldsUnchanged() {

      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['accessTier', 'premiumSource', 'premiumGrantedAt', 'institutionToken']);

    }



    match /apps/sanidapp/sanatorios/{sanatorioId} {

      allow read: if isSignedIn();

      allow write: if isAdmin();



      match /usuarios/{uid} {

        allow read: if isSelf(uid) || isAdmin() || isSupervisorOf(sanatorioId);

        allow create: if isSelf(uid);

        allow update: if isAdmin() || (isSelf(uid) && roleUnchanged() && premiumFieldsUnchanged());

        allow delete: if isAdmin();

      }



      match /foroPosts/{postId} {

        allow read: if canReadForoPost(sanatorioId, resource.data);

        allow create: if (isSupervisorOf(sanatorioId) || isAdmin())

          && request.resource.data.sanatorioId == sanatorioId

          && request.resource.data.authorUid == request.auth.uid

          && request.resource.data.title is string

          && request.resource.data.body is string

          && request.resource.data.type in ['notificacion', 'evento', 'planificacion', 'directa']

          && (

            request.resource.data.type != 'directa'

            || (

              request.resource.data.targetUid is string

              && request.resource.data.targetUid.size() > 0

              && request.resource.data.targetName is string

              && request.resource.data.targetName.size() > 0

            )

          );

        allow update: if (isSupervisorOf(sanatorioId) || isAdmin())

          && request.resource.data.sanatorioId == resource.data.sanatorioId

          && request.resource.data.authorUid == resource.data.authorUid;

        allow delete: if isSupervisorOf(sanatorioId) || isAdmin();

      }



      match /pushTokens/{uid} {

        allow read: if isSelf(uid) || isAdmin();

        allow create, update: if isSelf(uid)

          && belongsToSanatorio(sanatorioId)

          && request.resource.data.uid == request.auth.uid

          && request.resource.data.sanatorioId == sanatorioId

          && request.resource.data.expoPushToken is string

          && request.resource.data.role in ['user', 'supervisor'];

        allow delete: if isSelf(uid) || isAdmin();

      }

    }



    match /apps/sanidapp/usuarios/{uid} {

      allow read: if isSelf(uid) || isAdmin();

      allow create: if isSelf(uid);

      allow update: if isAdmin() || (isSelf(uid) && roleUnchanged() && premiumFieldsUnchanged());

      allow delete: if isAdmin();

    }



    match /apps/sanidapp/config/admins {

      allow read: if isSignedIn() && (

        !exists(/databases/$(database)/documents/apps/sanidapp/config/admins)

        || isAdmin()

      );

      allow create: if isSignedIn()

        && !exists(/databases/$(database)/documents/apps/sanidapp/config/admins)

        && request.resource.data.uids is list

        && request.auth.uid in request.resource.data.uids;

      allow update: if isAdmin();

    }



    match /apps/sanidapp/purchases/{uid} {

      allow read: if isSelf(uid) || isAdmin();

      allow write: if false;

    }



    match /{document=**} {

      allow read, write: if false;

    }

  }

}


